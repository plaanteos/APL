generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Administrador {
  id                   Int              @id @default(autoincrement())
  nombre               String           @db.VarChar(100)
  telefono             String           @db.VarChar(20)
  email                String           @unique @db.VarChar(100)
  usuario              String           @unique @db.VarChar(50)
  super_usuario        Boolean          @default(false)
  password             String
  twoFactorEnabled     Boolean          @default(false) @map("two_factor_enabled")
  twoFactorSecret      String?          @map("two_factor_secret")
  twoFactorBackupCodes Json?            @map("two_factor_backup_codes")
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  activo               Boolean          @default(true)
  refreshToken         String?
  resetPasswordToken   String?
  resetPasswordExpiry  DateTime?
  clientes             Cliente[]
  messages             Message[]
  otrosGastos          OtroGasto[]
  pagos                Pago[]
  pedidos              Pedido[]
  productos            Producto[]
  whatsappSession      WhatsAppSession?

  @@map("administrador")
}

// ==============================
// TIPO CLIENTE
// ==============================
model tipo_cliente {
  id           Int       @id @default(autoincrement())
  descripcion  String    @db.VarChar(50)
  fecha_insert DateTime? @default(now())
  fecha_delete DateTime?

  clientes    Cliente[]

  @@map("tipo_cliente")
}

model Cliente {
  id               Int           @id @default(autoincrement())
  nombre           String        @db.VarChar(100)
  telefono         String        @db.VarChar(20)
  email            String        @db.VarChar(100)
  id_administrador Int
  celular          String?      @db.VarChar(20)
  id_tipo          Int?

  administrador    Administrador @relation(fields: [id_administrador], references: [id])
  tipo_cliente     tipo_cliente? @relation(fields: [id_tipo], references: [id], onDelete: SetNull)
  messages         Message[]
  pedidos          Pedido[]

  @@index([id])
  @@index([id_administrador])
  @@index([nombre])
  @@index([telefono])
  @@index([id_tipo])
  @@unique([id_administrador, email])
  @@map("cliente")
}

model Pedido {
  id               Int             @id @default(autoincrement())
  id_cliente       Int
  fecha_insert     DateTime        @default(now())
  fecha_update     DateTime        @updatedAt
  fecha_pedido     DateTime        @default(now())
  fecha_entrega    DateTime
  fecha_delete     DateTime?
  id_administrador Int
  descripcion      String?
  detallesPago     DetallePago[]
  detalles         DetallePedido[]
  administrador    Administrador   @relation(fields: [id_administrador], references: [id])
  cliente          Cliente         @relation(fields: [id_cliente], references: [id], onDelete: Cascade)

  @@index([id_cliente])
  @@index([id_administrador])
  @@index([fecha_update])
  @@index([fecha_pedido])
  @@index([fecha_entrega])
  @@index([fecha_delete])
  @@map("pedidos")
}

model Producto {
  id               Int             @id @default(autoincrement())
  tipo             String          @db.VarChar(100)
  id_administrador Int
  detalles         DetallePedido[]
  administrador    Administrador   @relation(fields: [id_administrador], references: [id])

  @@index([id_administrador])
  @@index([tipo])
  @@map("producto")
}

model DetallePedido {
  id              Int      @id @default(autoincrement())
  id_pedido       Int
  id_producto     Int
  cantidad        Int
  precio_unitario Decimal  @db.Decimal(10, 2)
  paciente        String   @db.VarChar(100)
  id_estado       Int
  estado          Estado   @relation(fields: [id_estado], references: [id])
  pedido          Pedido   @relation(fields: [id_pedido], references: [id], onDelete: Cascade)
  producto        Producto @relation(fields: [id_producto], references: [id])

  @@index([id_pedido])
  @@index([id_producto])
  @@index([id_estado])
  @@map("detalle_pedidos")
}

model Estado {
  id           Int             @id @default(autoincrement())
  descripcion  String          @unique @db.VarChar(50)
  fecha_insert DateTime        @default(now())
  fecha_delete DateTime?
  detalles     DetallePedido[]

  @@index([fecha_delete])
  @@map("estado")
}

model Pago {
  id               Int           @id @default(autoincrement())
  valor            Decimal       @db.Decimal(10, 2)
  id_administrador Int
  detalles         DetallePago[]
  administrador    Administrador @relation(fields: [id_administrador], references: [id])

  @@index([id_administrador])
  @@map("pago")
}

model DetallePago {
  id         Int      @id @default(autoincrement())
  id_pago    Int
  id_pedido  Int
  valor      Decimal  @db.Decimal(10, 2)
  fecha_pago DateTime
  pago       Pago     @relation(fields: [id_pago], references: [id], onDelete: Cascade)
  pedido     Pedido   @relation(fields: [id_pedido], references: [id], onDelete: Cascade)

  @@index([id_pedido])
  @@index([id_pago])
  @@index([fecha_pago])
  @@map("detalle_pago")
}

model Auditoria {
  id           Int      @id @default(autoincrement())
  usuario      String   @db.VarChar(50)
  fecha_accion DateTime @default(now())
  accion       String   @db.VarChar(100)

  @@index([fecha_accion])
  @@index([usuario])
  @@map("auditoria")
}

model OtroGasto {
  id               Int           @id @default(autoincrement())
  tipo             String        @db.VarChar(20)
  descripcion      String
  monto            Decimal       @db.Decimal(10, 2)
  fecha            DateTime      @default(now())
  id_administrador Int
  administrador    Administrador @relation(fields: [id_administrador], references: [id])

  @@index([id_administrador])
  @@index([fecha])
  @@index([tipo])
  @@map("otro_gasto")
}

model WhatsAppSession {
  id            Int           @id @default(autoincrement())
  userId        Int           @unique @map("user_id")
  sessionData   Json          @map("session_data")
  phoneNumber   String?       @map("phone_number") @db.VarChar(20)
  connectedAt   DateTime?     @default(now()) @map("connected_at") @db.Timestamptz(6)
  createdAt     DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  administrador Administrador @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_whatsapp_user")

  @@index([userId], map: "idx_whatsapp_sessions_user_id")
  @@map("whatsapp_sessions")
}

model Message {
  id                Int           @id @default(autoincrement())
  userId            Int           @map("user_id")
  clientId          Int           @map("client_id")
  content           String
  direction         String        @db.VarChar(20)
  status            String        @db.VarChar(20)
  whatsappMessageId String?       @map("whatsapp_message_id") @db.VarChar(100)
  createdAt         DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  cliente           Cliente       @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_message_client")
  administrador     Administrador @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_message_user")

  @@index([clientId], map: "idx_messages_client_id")
  @@index([createdAt], map: "idx_messages_created_at")
  @@index([userId], map: "idx_messages_user_id")
  @@map("messages")
}
